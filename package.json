    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^22",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
